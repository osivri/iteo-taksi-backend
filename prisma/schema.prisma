generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  DRIVER
  PLATE_OWNER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PASSIVE
  PENDING_VERIFICATION
}

enum VehicleStatus {
  ACTIVE
  PASSIVE
}

enum FinanceType {
  INCOME
  EXPENSE
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentType {
  DUES
  APP_FEE
  SERVICE_FEE
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

enum AppointmentType {
  HOTEL
  AUTO_SERVICE
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum OhsContentType {
  VIDEO
  ARTICLE
  GUIDE
  FAQ
}

enum NotificationType {
  ANNOUNCEMENT
  NEWS
  PAYMENT
  APPOINTMENT
  SYSTEM
}

model User {
  id              String     @id @default(uuid())
  firstName       String
  lastName        String
  phone           String     @unique
  email           String?
  nationalId      String?
  memberNo        String?
  role            UserRole   @default(USER)
  status          UserStatus @default(PENDING_VERIFICATION)
  profileImageUrl String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownedVehicles   Vehicle[]       @relation("VehicleOwner")
  drivenVehicles  Vehicle[]       @relation("VehicleDriver")
  financeRecords  FinanceRecord[]
  payments        Payment[]
  appointments    Appointment[]
  notifications   Notification[]
}

model Vehicle {
  id             String        @id @default(uuid())
  plateNumber    String        @unique
  brand          String?
  model          String?
  year           Int?
  ownerId        String
  activeDriverId String?
  status         VehicleStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner          User            @relation("VehicleOwner", fields: [ownerId], references: [id])
  activeDriver   User?           @relation("VehicleDriver", fields: [activeDriverId], references: [id])
  financeRecords FinanceRecord[]
  appointments   Appointment[]
}

model FinanceRecord {
  id              String      @id @default(uuid())
  userId          String
  vehicleId       String?
  type            FinanceType
  category        String
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("TRY")
  recordDate      DateTime
  description     String?
  receiptImageUrl String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Announcement {
  id            String               @id @default(uuid())
  title         String
  content       String
  category      String
  priority      AnnouncementPriority @default(NORMAL)
  coverImageUrl String?
  isPublished   Boolean              @default(false)
  sendPush      Boolean              @default(false)
  publishedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model News {
  id            String    @id @default(uuid())
  title         String
  summary       String
  content       String
  category      String
  coverImageUrl String?
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  type                  PaymentType
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("TRY")
  status                PaymentStatus @default(PENDING)
  provider              String        @default("mock")
  providerTransactionId String?
  receiptUrl            String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Appointment {
  id            String            @id @default(uuid())
  userId        String
  type          AppointmentType
  status        AppointmentStatus @default(PENDING)
  requestedDate DateTime
  requestedTime String?
  description   String?
  adminNote     String?
  checkInDate   DateTime?
  checkOutDate  DateTime?
  guestCount    Int?
  roomType      String?
  vehicleId     String?
  plateNumber   String?
  serviceType   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
}

model OhsContent {
  id          String         @id @default(uuid())
  title       String
  description String?
  type        OhsContentType
  category    String
  videoUrl    String?
  body        String?
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}
